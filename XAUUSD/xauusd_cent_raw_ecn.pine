//@version=5
strategy(
  title="XAUUSD Cent Raw ECN — Realistic",
  shorttitle="XAUUSD Cent",
  overlay=true,
  default_qty_type=strategy.percent_of_equity,
  default_qty_value=2.0,
  commission_type=strategy.commission_per_lot,
  commission_value=0.06,      // $0.06 RT per cent lot
  pyramiding=0,
  slippage=3,
  initial_capital=500,
  currency=currency.USD
)

// ══════════════════════════════════════════════
//  INPUTS
// ══════════════════════════════════════════════

// — Risk —
riskPct    = input.float(1.0,   "Risk per trade (%)",      minval=0.5,  maxval=3.0,  step=0.25)
atrMult    = input.float(1.2,   "ATR mult for SL",         minval=0.5,  maxval=3.0,  step=0.1)
atrLen     = input.int(14,      "ATR length",              minval=7,    maxval=30)
rrTarget   = input.float(2.0,   "Full RR target",          minval=1.5,  maxval=4.0,  step=0.5)

// — Partial TP & trail —
partialPct = input.int(50,      "Partial TP % at 1:1",     minval=25,   maxval=75,   step=5)
trailMult  = input.float(0.7,   "Trail offset (× ATR)",    minval=0.3,  maxval=2.0,  step=0.05)
useTrail   = input.bool(true,   "Enable trailing stop")

// — Breakers —
maxConsecLoss = input.int(2,    "Max consecutive losses",  minval=1,    maxval=5)
dailyLossPct  = input.float(5.0,"Max daily loss (%)",      minval=2.0,  maxval=15.0)
maxDDpct      = input.float(20.0,"Max total DD (%)",       minval=10.0, maxval=40.0)

// — Strategy —
fastLen    = input.int(20,      "Fast EMA",                minval=5,    maxval=50)
slowLen    = input.int(50,      "Slow EMA",                minval=20,   maxval=100)
rsiLen     = input.int(7,       "RSI length",              minval=3,    maxval=14)
rsiThresh  = input.int(30,      "RSI oversold threshold",  minval=20,   maxval=45)
dir        = input.string("Both","Direction",              options=["Long only","Short only","Both"])

// — Session — XAUUSD most volatile during NY (13:00–20:00 GMT)
// London/NY overlap 13:00–16:00 is the sweet spot
sStart     = input.int(12,      "Session start (GMT)",     minval=0,    maxval=23)
sEnd       = input.int(20,      "Session end (GMT)",       minval=1,    maxval=23)
inSession  = time(timeframe.period, str.tostring(sStart) + ":00-" + str.tostring(sEnd) + ":00:12345")

// — News filter —
useNewsFX  = input.bool(true,   "Enable news filter")
blockMin   = input.int(45,      "Block X min before news", minval=15,   maxval=120, step=5)
postMin    = input.int(15,      "Wait X min after news",   minval=5,    maxval=60,  step=5)

// Default XAUUSD high-impact news hours (GMT)
newsUS1330 = input.bool(true,   "US data 13:30 GMT (NFP/CPI)")
newsUS14   = input.bool(false,  "US data 14:00 GMT")
newsUS15   = input.bool(false,  "US data 15:00 GMT")
newsCustomH = input.int(0,      "Custom news hour (GMT)",  minval=0,    maxval=23)
newsCustomM = input.int(0,      "Custom news minute",      minval=0,    maxval=59)

// ══════════════════════════════════════════════
//  NEWS BLACKOUT CALC
// ══════════════════════════════════════════════
inNewsBlackout() =>
    ch = hour; cm = minute
    blocked = false
    check(eh, em) =>
        bs = (eh*60 + em - blockMin + 1440) % 1440
        be = (eh*60 + em + postMin + 1440) % 1440
        now = ch*60 + cm
        if bs < be
            now >= bs and now <= be
        else
            now >= bs or now <= be
    if useNewsFX
        if newsUS1330 and check(13,30) => blocked := true
        if newsUS14   and check(14,0)  => blocked := true
        if newsUS15   and check(15,0)  => blocked := true
        if newsCustomH > 0 and check(newsCustomH, newsCustomM) => blocked := true
    blocked

newsActive = inNewsBlackout()

// Post-news momentum window
postNewsActive = false
if useNewsFX
    mn = hour*60 + minute
    for [eh, em] in [[13,30], [14,0], [15,0]]
        w = eh*60 + em + postMin
        we = eh*60 + em + postMin + 30
        if mn >= w and mn <= we
            postNewsActive := true
    if newsCustomH > 0
        cw = newsCustomH*60 + newsCustomM + postMin
        cwe = newsCustomH*60 + newsCustomM + postMin + 30
        if mn >= cw and mn <= cwe
            postNewsActive := true

// ══════════════════════════════════════════════
//  INDICATORS
// ══════════════════════════════════════════════
fastMA = ta.ema(close, fastLen)
slowMA = ta.ema(close, slowLen)
rsi    = ta.rsi(close, rsiLen)
atr    = ta.atr(atrLen)

pipVal  = 0.01                               // XAUUSD pip = 0.01
uptrend    = fastMA > slowMA
downtrend  = fastMA < slowMA

longCond   = inSession and uptrend and ta.crossover(rsi, rsiThresh)
shortCond  = inSession and downtrend and ta.crossunder(rsi, 100 - rsiThresh)

// Momentum window — relaxed RSI entry
longMom    = inSession and uptrend and ta.crossover(rsi, rsiThresh + 10)
shortMom   = inSession and downtrend and ta.crossunder(rsi, 90 - rsiThresh)

goLong  = (longCond or (postNewsActive and longMom)) and (dir == "Long only" or dir == "Both") and not newsActive
goShort = (shortCond or (postNewsActive and shortMom)) and (dir == "Short only" or dir == "Both") and not newsActive

// ══════════════════════════════════════════════
//  CIRCUIT BREAKERS
// ══════════════════════════════════════════════
var int   consecLosses   = 0
var int   lastTradeCnt   = 0
var int   curDay         = -1
var float dayStartEq     = na

if strategy.closedtrades > lastTradeCnt
    lastTradeCnt := strategy.closedtrades
    if strategy.closedtrades.profit(strategy.closedtrades - 1) < 0
        consecLosses += 1
    else
        consecLosses := 0

if dayofmonth != curDay
    curDay    := dayofmonth
    dayStartEq := strategy.equity + strategy.openprofit

dailyPnl   = strategy.equity + strategy.openprofit - dayStartEq
dailyLossPctActual = -dailyPnl / dayStartEq * 100
totalDD    = (strategy.initial_capital - strategy.equity) / strategy.initial_capital * 100

allowed = true
reason  = ""
if consecLosses >= maxConsecLoss
    allowed := false; reason := str.tostring(maxConsecLoss) + " SL hits — locked"
if dailyLossPctActual >= dailyLossPct
    allowed := false; reason := "Daily loss limit"
if totalDD >= maxDDpct
    allowed := false; reason := "Max drawdown"
if newsActive and not postNewsActive
    allowed := false; reason := "News blackout"

// ══════════════════════════════════════════════
//  POSITION SIZING
// ══════════════════════════════════════════════
eq      = strategy.equity
riskUSD = eq * riskPct / 100.0
// For XAUUSD cent lot: pip value = ~$0.10 per pip per cent lot
// 1 cent lot = 0.01 standard lot = 1 oz
// atr is in price ($), convert to pips: atr / 0.01
slPips  = math.max(atr * atrMult / pipVal, 30)    // min 30 pips for gold
slPips  := math.round(slPips, 1)
tpPips  = slPips * rrTarget

// Pip value per cent lot for XAUUSD ≈ $0.10
pipValCent = 0.10
sizeLots   = math.floor(riskUSD / (slPips * pipValCent * 100) * 100) / 100  // round to 0.01
sizeLots   = math.max(sizeLots, 0.01)
sizeLots   = math.min(sizeLots, 10)   // cap at 10 cent lots

// ══════════════════════════════════════════════
//  ENTRY & EXIT
// ══════════════════════════════════════════════
var float entryPrice  = na
var float initSize    = 0.0
var bool  partialHit  = false
var float trailStop   = na

if goLong and allowed and strategy.position_size == 0
    strategy.entry("Long",  strategy.long,  qty=sizeLots)
    entryPrice  := close; initSize := strategy.position_size; partialHit := false; trailStop := na

if goShort and allowed and strategy.position_size == 0
    strategy.entry("Short", strategy.short, qty=sizeLots)
    entryPrice  := close; initSize := strategy.position_size; partialHit := false; trailStop := na

if strategy.position_size != 0
    slPrice  = entryPrice - slPips * pipVal
    tp1Price = entryPrice + slPips * pipVal
    if strategy.position_size < 0
        slPrice  := entryPrice + slPips * pipVal
        tp1Price := entryPrice - slPips * pipVal

    remaining = math.abs(strategy.position_size) / math.abs(initSize)
    if remaining < 0.75
        partialHit := true

    if not partialHit
        strategy.exit("SL",  from_entry="Long",  stop=slPrice)
        strategy.exit("SL",  from_entry="Short", stop=slPrice)
        strategy.exit("TP1", from_entry="Long",  limit=tp1Price)
        strategy.exit("TP1", from_entry="Short", limit=tp1Price)
    else
        if useTrail
            trl = atr * trailMult
            if strategy.position_size > 0
                ns = high - trl
                trailStop := na(trailStop) ? ns : math.max(trailStop, ns)
                trailStop := math.max(trailStop, entryPrice)
                strategy.exit("Trail", from_entry="Long", stop=trailStop)
            else
                ns = low + trl
                trailStop := na(trailStop) ? ns : math.min(trailStop, ns)
                trailStop := math.min(trailStop, entryPrice)
                strategy.exit("Trail", from_entry="Short", stop=trailStop)
        else
            strategy.exit("BE", from_entry="Long",  stop=entryPrice)
            strategy.exit("BE", from_entry="Short", stop=entryPrice)

// ══════════════════════════════════════════════
//  PLOTS
// ══════════════════════════════════════════════
plot(fastMA, "Fast EMA", color.blue, 1)
plot(slowMA, "Slow EMA", color.orange, 1)

plotshape(goLong and allowed,  "Buy",  shape.triangleup,   location.belowbar, color.green, size=size.small)
plotshape(goShort and allowed, "Sell", shape.triangledown, location.abovebar, color.red,   size=size.small)

// News zones
bgcolor(newsActive and not postNewsActive ? color.new(color.magenta, 85) : na, title="News blackout")
bgcolor(postNewsActive ? color.new(color.lime, 88) : na, title="Post-news momentum")

// Status
var label lbl = na
if barstate.islast
    if not allowed
        lbl := label.new(bar_index, low - atr * 3,
             "⛔ " + reason + "  [Streak: " + str.tostring(consecLosses) + "]" +
             (newsActive ? "  📰 News" : ""),
             color=color.new(color.red, 70), textcolor=color.white, style=label.style_label_lower_left, size=size.normal)
    else
        lbl := label.new(bar_index, low - atr * 3,
             "✓ Active  Risk: $" + str.tostring(riskUSD, "#.##") +
             "  Size: " + str.tostring(sizeLots, "#.##") + " lots" +
             "  Streak: " + str.tostring(consecLosses) +
             (postNewsActive ? "  📰 Post-news" : ""),
             color=color.new(color.green, 60), textcolor=color.white, style=style.label_lower_left, size=size.normal)

if barstate.islast
    label.new(bar_index, high + atr * 4,
         "Daily: " + str.tostring(dailyPnl, "+#.#;-#.#") + "$  DD: " + str.tostring(totalDD, "#.#") + "%",
         color=color.new(color.gray, 80), textcolor=color.white, style=label.style_label_upper_left, size=size.small)

// ══════════════════════════════════════════════
//  ALERTS
// ══════════════════════════════════════════════
alertcondition(goLong  and allowed, "XAUUSD Buy", "XAUUSD BUY @ {{close}}")
alertcondition(goShort and allowed, "XAUUSD Sell", "XAUUSD SELL @ {{close}}")
alertcondition(not allowed, "XAUUSD Breaker", "XAUUSD — " + reason)
